# API Service Configuration
API_PORT=3000
NODE_ENV=development

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_QUEUE=user_activities

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50

# Database Configuration (MongoDB - choose one)
DB_TYPE=mongodb
MONGODB_URL=mongodb://user:password@database:27017/activity_db?authSource=admin
MONGODB_USER=user
MONGODB_PASSWORD=password
MONGODB_DATABASE=activity_db

# Database Configuration (MySQL - alternative)
# DB_TYPE=mysql
# MYSQL_HOST=database
# MYSQL_PORT=3306
# MYSQL_USER=user
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=activity_db